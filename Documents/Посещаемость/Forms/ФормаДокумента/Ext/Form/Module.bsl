&НаКлиенте
Процедура ГруппаПриИзменении(Элемент)
	
	ГруппаПриИзмененииНаСервере();
	
	Объект.ДатаЭкзамена = ПолучитьДатаЭкзамена(Объект.Группа);
	Объект.ДатаКурсовой= ПолучитьДатаКурсовой(Объект.Группа);
	Объект.Курс= ПолучитьКурс(Объект.Группа);

	Если ПустаяСтрока(Объект.Группа) Тогда 
		Элементы.Группа3.Видимость=Ложь;	
	Иначе	
		Элементы.Группа3.Видимость=Истина;
	КонецЕсли;
	
	Если Объект.НесколькоГрупп=Истина Тогда
		Объект.КоличествоГрупп=Объект.КоличествоГрупп+"; "+Объект.Группа;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура Сумма()
	
	Если Объект.ВидЗанятия=ПредопределенноеЗначение("Перечисление.ВидЗанятия.ЗащитаКурсовой") Или Объект.ВидЗанятия=ПредопределенноеЗначение("Перечисление.ВидЗанятия.Консультация") 
		ИЛИ Объект.ВидЗанятия=ПредопределенноеЗначение("Перечисление.ВидЗанятия.Экзамен") 
		ИЛИ Объект.ВидЗанятия=ПредопределенноеЗначение("Перечисление.ВидЗанятия.Зачет")
		ИЛИ Объект.ВидЗанятия=ПредопределенноеЗначение("Перечисление.ВидЗанятия.Защита_ВКР_бакалавров")Тогда 
		Элементы.КоличествоЧасов.Доступность=Истина;
		Объект.КоличествоЧасов=ПолучитьЦенуСтудента(Объект.Дата,Объект.ОплатаЗаПериод)*Объект.СколькоПришлоСтудентов;
	Иначе
		Объект.КоличествоЧасов=Объект.Пары*2;
	КонецЕсли;

		Объект.Итого=Объект.СуммаКВыдаче*Объект.КоличествоЧасов;

КонецПроцедуры


&НаКлиенте
Процедура ПарыПриИзменении(Элемент)
	
Сумма();

КонецПроцедуры

