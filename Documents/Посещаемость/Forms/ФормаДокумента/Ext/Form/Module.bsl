					НоваяЗапись.Группа =НомерГруппы;
				КонецЕсли;
				//НоваяЗапись.НаЧтоЗапланированы = Объект.ВидЗанятия; 
				НоваяЗапись.УчебныйГод = Объект.ОплатаЗаПериод;
				НоваяЗапись.Дисциплина = Объект.Дисциплина;
				НоваяЗапись.ДЗ = Объект.ДомашнееЗадание;
				//НоваяЗапись.КоличествоЧасов = Объект.КоличествоЧасов;
				//НоваяЗапись.КОплате = Объект.Итого;
			//КонецЕсли;
		КонецЕсли;
		
		НаборЗаписейДЗ.Записать();
КонецПроцедуры


&НаКлиенте
Процедура НесколькоГруппПриИзменении(Элемент)
	Если Объект.НесколькоГрупп=Истина тогда
		Объект.КоличествоГрупп="";
		Элементы.ГруппыТЧ.Видимость=Истина;
		Элементы.Группа.Доступность=ложь;
		Объект.КоличествоГрупп=Объект.Группа;
	Иначе
		Элементы.ГруппыТЧ.Видимость=Ложь;
		Объект.КоличествоГрупп="";
		Элементы.Группа.Доступность=Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьЦенуТовара(Дата,УчГод, Группа, Дисциплина, НаЧтоЗапланированы)
    
	Отбор = Новый Структура("УчГод,Группа,Дисциплина,НаЧтоЗапланированы", УчГод,Группа,Дисциплина,НаЧтоЗапланированы);
	ЦенаТовара = РегистрыСведений.ПланПоЧасам.ПолучитьПоследнее(Дата,Отбор);
	Возврат ЦенаТовара.КоличествоЧасов;
	    
КонецФункции


&НаКлиенте
Процедура ГруппыТЧГруппаПриИзменении(Элемент)

	ТЧ=Элементы.ГруппыТЧ.ТекущиеДанные;
	НомерГруппы=ТЧ.Группа;
	ТЧ.КоличествоЧасов = ПолучитьЦенуТовара(ТекущаяДата(),Объект.ОплатаЗаПериод, ТЧ.Группа, Объект.Дисциплина, Объект.ВидЗанятия);
	ГруппаНаСервере();
	

КонецПроцедуры

