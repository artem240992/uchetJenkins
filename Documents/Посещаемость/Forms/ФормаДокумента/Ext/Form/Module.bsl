
&НаСервере
Процедура ГруппаПриИзмененииНаСервере()
	
	Если Объект.НесколькоГрупп=Ложь Тогда
		Объект.Студенты.Очистить();
	КонецЕсли;
	
	//Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	Студенты.Ссылка КАК Студент,
		               |	Студенты.ТемаКурсовой КАК ТемаКурсовой,
		               |	Студенты.Группа КАК Группа
		               |ИЗ
		               |	Справочник.Студенты КАК Студенты
		               |ГДЕ
		               |	Студенты.Группа = &Группа
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Студенты.Ссылка";
		Запрос.УстановитьПараметр("Группа", Объект.Группа);
		Результат=Запрос.Выполнить().Выгрузить();
		Объект.Студенты.Загрузить(Результат);
	//КонецЕсли;
	
		
КонецПроцедуры


