&НаСервере
Процедура УстановитьКомандыПечать()
	
	    ИмяКоманды = "КонсультационныйЛист";
	Если Команды.Найти(ИмяКоманды) = Неопределено Тогда
		НоваяКоманда = Команды.Добавить(ИмяКоманды);
	    НоваяКоманда.Действие  = "КонсЛист";
    	НоваяКнопка = Элементы.Добавить("ФормаПечатьКонсультационныйЛист", Тип("КнопкаФормы"), КоманднаяПанель);
		НоваяКнопка.Заголовок = "Отзыв к курсовой";
		НоваяКнопка.ИмяКоманды = ИмяКоманды;
	КонецЕсли;	
