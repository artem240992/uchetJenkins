&НаКлиенте
Процедура ПриказОКонсультантахМ(Документ, MSWord, ИмяВременногоФайла, Сколько = "", СписокСтрок = Неопределено)

	//КоличествоСтрокВТЧ = Объект.Студенты.Итог("КоличествоСтрок");
	СписокСтрок = Новый Массив;
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Выбран", Истина);
	ВыбранныеСтроки = Объект.Студенты.НайтиСтроки(ПараметрыОтбора);
	
	Для каждого ВыбраннаяСтрока из ВыбранныеСтроки Цикл
		
		СписокСтрок.Добавить(ВыбраннаяСтрока);
		
	КонецЦикла;
	
	Если Сколько = "" Тогда // только выбранные строки
		
		КоличествоСтрок = СписокСтрок.Количество();
		НомерСтроки = 0; 
		
		Для каждого Данные Из СписокСтрок Цикл

			Для каждого СтрокаСумм Из Объект.Студенты Цикл
				Если СтрокаСумм.Выбран = Истина Тогда 
					для А=1 По 17 Цикл  
						Замена = Документ.Content.Find; 
						Замена.Execute("<Дисциплина>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Объект.Дисциплина));
						Замена.Execute("<Тема>", Ложь, Истина, Ложь, , , Истина, , Ложь, СокрЛП(Данные.ТемаКурсовой));
						Замена.Execute("<Студент>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.Студент));
						Замена.Execute("<Курс>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Объект.Курс));
						Замена.Execute("<Группа>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Объект.Группа));
						Замена.Execute("<Руководитель Курсовой>", Ложь, Истина, Ложь, , , Истина, , Ложь, "");	
			    		СтепеньРаскрытияТемы = СтрокаСумм.СтепеньРаскрытияТемы;
			    		ПолнотаОхватаНаучнойЛитературы = СтрокаСумм.ПолнотаОхватаНаучнойЛитературы;
						ИспользованиеНормативныхАктов = СтрокаСумм.ИспользованиеНормативныхАктов;
						ИндивидуальностьПодходаКНаписаниюКР = СтрокаСумм.ИндивидуальностьПодходаКНаписаниюКР;
						ПоследовательностьИЛогикаИзложенияМатериала = СтрокаСумм.ПоследовательностьИЛогикаИзложенияМатериала;
						КачествоОформления = СтрокаСумм.КачествоОформления;
						ИспользованиеИллюстративногоМатериала = СтрокаСумм.ИспользованиеИллюстративногоМатериала;
						Защита = СтрокаСумм.Защита;
						Баллов = СтрокаСумм.Баллов;
						Замена = Документ.Content.Find;			
						Замена.Execute("<СтепеньРаскрытияТемы>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.СтепеньРаскрытияТемы,"ЧН=0"));
						Замена.Execute("<ПолнотаОхватаНаучнойЛитературы>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.ПолнотаОхватаНаучнойЛитературы,"ЧН=0"));
						Замена.Execute("<ИспользованиеНормативныхАктов>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.ИспользованиеНормативныхАктов,"ЧН=0"));
						Замена.Execute("<ИндивидуальностьПодходаКНаписаниюКР>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.ИндивидуальностьПодходаКНаписаниюКР,"ЧН=0"));
						Замена.Execute("<ПоследовательностьИЛогикаИзложенияМатериала>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.ПоследовательностьИЛогикаИзложенияМатериала,"ЧН=0"));
						Замена.Execute("<КачествоОформления>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.КачествоОформления,"ЧН=0"));
						Замена.Execute("<ИспользованиеИллюстративногоМатериала>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.ИспользованиеИллюстративногоМатериала,"ЧН=0"));
						Замена.Execute("<Защита>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.Защита,"ЧН=0"));
						Замена.Execute("<ИтогСодержания>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.СтепеньРаскрытияТемы+Данные.ПолнотаОхватаНаучнойЛитературы+Данные.ИспользованиеНормативныхАктов+Данные.ИндивидуальностьПодходаКНаписаниюКР+Данные.ПоследовательностьИЛогикаИзложенияМатериала,"ЧН=0"));
						Замена.Execute("<ИтогОФормление>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.КачествоОформления + Данные.ИспользованиеИллюстративногоМатериала,"ЧН=0"));
						Замена.Execute("<ОбщийИтог>", Ложь, Истина, Ложь, , , Истина, , Ложь, Формат(Данные.Баллов,"ЧН=0"));
					КонецЦикла;	
				Иначе
					//Сообщить(СтрокаСумм.Студент + " не выбран для печати отзыва");
				КонецЕсли;
			КонецЦикла;
					
			НомерСтроки = НомерСтроки + 1;
			
			Если НомерСтроки <> КоличествоСтрок Тогда
				Документ.sections.add(Документ.characters.last,2).Range.Select(); 
				MSWord.Selection.InsertFile(ИмяВременногоФайла);
			КонецЕсли; 
			
	КонецЦикла;

	MSWord.Visible = 1; 
	MSWord.Activate(); 
Иначе
	
КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура ВыбратьВсе(Команда)
	//Сообщить("Пока в разработке",СтатусСообщения.ОченьВажное);
	для Каждого СТЧ Из Объект.Студенты Цикл 
		Если СТЧ.Выбран = Ложь Тогда 
			СТЧ.Выбран = Истина;
		Иначе
			СТЧ.Выбран = Ложь;
