&НаКлиенте
Процедура ПолучениеОценки()
	
	ТЧ=Элементы.Студенты.ТекущиеДанные;
	
	Если ТЧ.Баллов<50 Тогда 
		ТЧ.Оценка = 2;
	ИначеЕсли ТЧ.Баллов>=50 и ТЧ.Баллов<=60 Тогда
		ТЧ.Оценка = 3;
	ИначеЕсли ТЧ.Баллов>=60 и ТЧ.Баллов<80 Тогда
		ТЧ.Оценка = 4;
	ИначеЕсли ТЧ.Баллов>=80 Тогда
		ТЧ.Оценка = 5;
	ИначеЕсли ТЧ.Баллов = 0 ИЛИ ТЧ.Баллов = " " Тогда
		ТЧ.Оценка =0;

	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура СтудентыБалловПриИзменении(Элемент)
	
	ПолучениеОценки();
	
КонецПроцедуры

&НаКлиенте
Процедура ОплатаЗаПериодПриИзменении(Элемент)
	
	Объект.СуммаКВыдаче=ПолучитьЦену(Объект.Дата,Объект.ОплатаЗаПериод);
	
	Объект.Итого=Объект.СуммаКВыдаче*Объект.КоличествоЧасов;
	
	ПересчитатьНаСервере();

КонецПроцедуры

